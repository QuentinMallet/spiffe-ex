# Nix-specific
.nix-mix/
.nix-hex/
result
result-*
# .omc: explicitly ignore ephemeral dirs, persistent artifacts tracked by default
# Using **/.omc/<dir> patterns covers both root and nested .omc/ dirs.
# Trade-off: must update this list if new ephemeral dirs are added to .omc/
**/.omc/state/
**/.omc/sessions/
**/.omc/autopilot/
**/.omc/drafts/
**/.omc/handoffs/
**/.omc/logs/
**/.omc/research/
**/.omc/prd*.json
**/.omc/progress.txt

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Test coverage
cover/
*.coverdata

# Temporary files
*.tmp
.elixir-tools/

# Phoenix specific
/priv/static/
/assets/node_modules/
npm-debug.log

# Database
*.db
*.db-shm
*.db-wal
